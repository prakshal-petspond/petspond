# ─── Core ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# MongoDB Atlas connection string (use separate DB names for dev vs prod)
# Example: mongodb+srv://user:pass@cluster.mongodb.net/petspond-dev?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/petspond

# Strong random secret — use a different value per environment
JWT_SECRET=change-me-use-openssl-rand-base64-32

# Public API URL (Railway assigns HTTPS URL — set after first deploy)
# Used for upload response URLs and email links
API_PUBLIC_URL=http://localhost:3000

# Comma-separated Vet CRM web origins (Netlify URLs). Required in production.
# Example: https://petspond-vet-dev.netlify.app,https://petspond-vet.netlify.app
CORS_ORIGINS=http://localhost:3001

# ─── Vet auth tokens ────────────────────────────────────────────────────────
VET_ACCESS_TOKEN_EXPIRES_SECONDS=900
VET_REFRESH_TOKEN_EXPIRES_DAYS=30

# ─── Email (Resend) ─────────────────────────────────────────────────────────
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# ─── Google OAuth (Vet CRM sign-in) ─────────────────────────────────────────
# Same Web client ID as NEXT_PUBLIC_GOOGLE_CLIENT_ID on the frontend
GOOGLE_CLIENT_ID=

# ─── OTP bypass (development only) ──────────────────────────────────────────
# Set OTP_BYPASS=false in production
OTP_BYPASS=true
OTP_BYPASS_CODE=123456

# ─── Phone OTP (optional — pick one provider) ─────────────────────────────────
OTP_PROVIDER=mock
# OTP_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# OTP_DEFAULT_COUNTRY_CODE=91

# ─── Cloudflare R2 (image uploads) ──────────────────────────────────────────
# See CLOUDFLARE_R2_SETUP.md
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=petspond

# ─── Stripe (optional — vet checkout) ───────────────────────────────────────
STRIPE_SECRET_KEY=
