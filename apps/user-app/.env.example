# API base URL for the Petspond backend.
# Used when calling send-otp, verify-otp, etc.
#
# - iOS Simulator / Android Emulator: localhost usually works if the API runs on this machine.
# - Physical device (Expo Go): use your computer's LAN IP so the phone can reach the API.
#   Example: EXPO_PUBLIC_API_URL=http://192.168.1.8:3000
#   (Use the same IP shown in the Expo "Metro waiting on" line, with port 3000.)
#
# Restart Expo after changing this file.
EXPO_PUBLIC_API_URL=http://localhost:3000
