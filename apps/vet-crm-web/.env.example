# API base URL — point to your Railway API service for each environment.
# Development: https://petspond-api-dev.up.railway.app
# Production:  https://petspond-api-prod.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:3000

# Google Maps (Clinic profile — search + pin). Enable "Maps JavaScript API" and "Places API".
# Restrict the key to your Netlify domain(s) in Google Cloud Console.
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Google OAuth (Vet CRM sign-in). Create an OAuth 2.0 Web client in Google Cloud Console.
# Authorized JavaScript origins (add both environments):
#   http://localhost:3001
#   https://petspond-vet-dev.netlify.app
#   https://petspond-vet-prod.netlify.app  (or your custom domain)
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=
