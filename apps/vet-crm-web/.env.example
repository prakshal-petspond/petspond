# API base URL. Vet CRM runs on port 3001; API should run on 3000.
# Use http://localhost:3000 when both run on the same machine.
# If you open Vet CRM from another device (e.g. phone), set this to your computer's IP, e.g. http://192.168.1.10:3000
NEXT_PUBLIC_API_URL=http://localhost:3000

# Google Maps (Clinic profile — search + pin). Enable "Maps JavaScript API" and "Places API" on the key.
# Optional: without this, clinic location is not captured from the map (address fields still work).
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Google OAuth (Vet CRM sign-in). Create an OAuth 2.0 Web client in Google Cloud Console.
# Authorized JavaScript origins: http://localhost:3001 (and your production Vet CRM URL).
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Vet auth tokens are short-lived access JWTs + rotating refresh tokens (stored server-side).
# Access token TTL is configured on the API via VET_ACCESS_TOKEN_EXPIRES_SECONDS (default 900 = 15 min).
